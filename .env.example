# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?options
#
# Examples:
# - Local: postgresql://postgres:password@localhost:5432/Timbanganten
# - Aiven: postgres://avnadmin:YOUR_PASSWORD@your-host.aivencloud.com:26935/defaultdb?sslmode=require&sslrootcert=certs/ca.pem
# - Render: postgres://username:password@your-host.render.com:5432/database_name
# - Supabase: postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres
# - Neon: postgresql://username:password@your-host.neon.tech/database_name?sslmode=require
#
DATABASE_URL=postgresql://postgres:password@localhost:5432/Timbanganten

# =============================================================================
# SSL CERTIFICATE (Required for Aiven and some other providers)
# =============================================================================
# If using Aiven or another provider that requires SSL certificate:
# 1. Download the CA certificate from your database provider
# 2. Save it to the 'certs' folder (e.g., certs/ca.pem)
# 3. Reference it in the DATABASE_URL: ?sslmode=require&sslrootcert=certs/ca.pem
#
# For providers like Render, Supabase, or Neon, SSL is usually handled automatically
# and you don't need a separate certificate file.

# =============================================================================
# JWT SECRET
# =============================================================================
# Secret key for JWT token generation and verification
# Generate a secure random string (at least 32 characters)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# =============================================================================
# NOTES
# =============================================================================
# - Never commit the actual .env file to version control
# - Always use strong, unique passwords and secrets in production
# - For local development, you can use simpler values
# - Make sure to update these values when deploying to production
